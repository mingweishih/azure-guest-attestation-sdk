# =============================================================================
# Azure Guest Attestation SDK - .gitignore
# =============================================================================

# Generated by Cargo
debug/
target/

# Rustfmt backup files
**/*.rs.bk

# MSVC Windows builds of rustc generate these
*.pdb

# Cargo mutants
**/mutants.out*/

# =============================================================================
# Native Libraries and DLLs
# =============================================================================

# Windows DLLs
*.dll
*.dll.exp
*.dll.lib

# Linux shared libraries  
*.so
*.so.*

# macOS dynamic libraries
*.dylib

# Static libraries
*.a
*.lib

# =============================================================================
# IDE and Editor Files
# =============================================================================

.idea/
.vscode/
*.code-workspace
.vs/
*.sublime-*
*.swp
*.swo
*~

# =============================================================================
# Operating System Files
# =============================================================================

Thumbs.db
Desktop.ini
.DS_Store
._*

# =============================================================================
# Logs and Temporary Files
# =============================================================================

*.log
*.tmp
*.temp

# =============================================================================
# Security
# =============================================================================

.env
.env.local
*.key
*.pem
*.p12
*.pfx

# =============================================================================
# Build and Test Outputs
# =============================================================================

/out/
/output/
test-results/
coverage/
