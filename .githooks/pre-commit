#!/usr/bin/env bash
# Pre-commit hook: verify cargo fmt and clippy before committing.
set -e

echo "pre-commit: checking cargo fmt..."
if ! cargo fmt -- --check 2>&1; then
    echo ""
    echo "ERROR: cargo fmt check failed. Run 'cargo fmt' and stage the changes."
    exit 1
fi

echo "pre-commit: checking cargo clippy..."
if ! cargo clippy --workspace --all-targets -- -D warnings 2>&1; then
    echo ""
    echo "ERROR: cargo clippy found warnings. Fix them before committing."
    exit 1
fi

echo "pre-commit: all checks passed."
